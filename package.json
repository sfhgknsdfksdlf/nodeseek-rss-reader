{
  "name": "nodeseek-rss-reader",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "cf:build": "node scripts/cloudflare-build.mjs",
    "deploy": "npm run cf:build && wrangler deploy --config .wrangler/generated-wrangler.jsonc",
    "deploy:generated": "wrangler deploy --config .wrangler/generated-wrangler.jsonc",
    "db:migrate:local": "wrangler d1 migrations apply nodeseek-rss-reader --local",
    "db:migrate": "wrangler d1 migrations apply nodeseek-rss-reader --remote",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260424.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.13.2"
  }
}
